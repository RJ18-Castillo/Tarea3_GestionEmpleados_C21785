@model IEnumerable<Tarea3_GestionEmpleados_C21785.Models.Empleado>

@{
    ViewData["Title"] = "Empleados";
}

<h2>Gestión de Empleados</h2>

<!-- 🔍 BUSCADOR -->
<form method="get" class="mb-3">
    <input type="text" name="busqueda" value="@ViewBag.Busqueda" placeholder="Buscar..." />
    <button type="submit">Buscar</button>
    <a asp-action="Index">Limpiar</a>
</form>

<p>Total: @ViewBag.TotalRegistros</p>
<p>Página @ViewBag.PaginaActual de @ViewBag.TotalPaginas</p>

<a asp-action="Create">➕ Nuevo Empleado</a>

<table border="1" cellpadding="5" cellspacing="0" class="mt-3">
    <thead>
        <tr>
            <th>Nombre Completo</th>
            <th>Departamento</th>
            <th>Salario</th>
            <th>Fecha Ingreso</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var emp in Model)
        {
            <tr>
                <td>@emp.NombreCompleto</td>
                <td>@emp.Departamento</td>
                <td>@emp.Salario</td>
                <td>@emp.FechaIngreso.ToShortDateString()</td>

                <!-- 🟢🔴 ESTADO -->
                <td>
                    @if (emp.Activo)
                    {
                        <span style="color:green; font-weight:bold;">Activo</span>
                    }
                    else
                    {
                        <span style="color:red; font-weight:bold;">Dado de Baja</span>
                    }
                </td>

                <!-- 🔄 ACCIONES -->
                <td>
                    <a asp-action="Edit" asp-route-id="@emp.Id">Editar</a>

                    <form asp-action="ToggleActivo" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@emp.Id" />
                        <button type="submit">
                            @(emp.Activo ? "Dar de Baja" : "Activar")
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- ⬅️➡️ PAGINACIÓN -->
<div class="mt-3">

    @if (ViewBag.PaginaActual > 1)
    {
        <a href="?pagina=@(ViewBag.PaginaActual - 1)&busqueda=@ViewBag.Busqueda">⬅️ Anterior</a>
    }
    else
    {
        <span>⬅️ Anterior</span>
    }

    |

    @if (ViewBag.PaginaActual < ViewBag.TotalPaginas)
    {
        <a href="?pagina=@(ViewBag.PaginaActual + 1)&busqueda=@ViewBag.Busqueda">Siguiente ➡️</a>
    }
    else
    {
        <span>Siguiente ➡️</span>
    }

</div>